# EASTWEST AWS CONFIG
# Reutiliza infraestructura Sima — prefijo eastwest/ en S3
export AWS_REGION="eu-west-1"
export AWS_DEFAULT_REGION="eu-west-1"
export S3_BUCKET="sima-egarmo-2026"
export S3_PREFIX="eastwest"
export KEY_NAME="sima-key-2026"
export KEY_PATH="$HOME/EastWestDM/aws/sima-key-2026.pem"
export SG_ID="sg-0660f93b80e45c70b"
export UBUNTU_AMI="ami-0f27749973e2399b6"
export IAM_INSTANCE_PROFILE="SIMA-S3-Instance-Profile"
export INSTANCE_TYPE="r6i.2xlarge"   # 8 vCPU, 64GB RAM, ~$0.50/hr on-demand
export SPOT_OPTIONS="MarketType=spot,SpotOptions={SpotInstanceType=one-time,InstanceInterruptionBehavior=terminate}"
echo "✅ EastWestDM config cargada"
